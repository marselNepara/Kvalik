<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style>
    <Style.Resources>
      <!-- Палитра: тёмный минимализм -->
      <Color x:Key="BgMain">#0D0D0D</Color>
      <Color x:Key="BgPanel">#141414</Color>
      <Color x:Key="BgCard">#1A1A1A</Color>
      <Color x:Key="BgInput">#111111</Color>
      <Color x:Key="Border">#2A2A2A</Color>
      <Color x:Key="Accent">#FFFFFF</Color>
      <Color x:Key="AccentMuted">#666666</Color>
      <Color x:Key="TextPrimary">#EEEEEE</Color>
      <Color x:Key="TextSecondary">#666666</Color>
      <Color x:Key="Danger">#CC3333</Color>
      <Color x:Key="Success">#2E7D32</Color>
      <Color x:Key="Warn">#7A6000</Color>

      <SolidColorBrush x:Key="BgMainBrush"      Color="{StaticResource BgMain}"/>
      <SolidColorBrush x:Key="BgPanelBrush"     Color="{StaticResource BgPanel}"/>
      <SolidColorBrush x:Key="BgCardBrush"      Color="{StaticResource BgCard}"/>
      <SolidColorBrush x:Key="BgInputBrush"     Color="{StaticResource BgInput}"/>
      <SolidColorBrush x:Key="BorderBrush"      Color="{StaticResource Border}"/>
      <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource Accent}"/>
      <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}"/>
      <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
      <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
      <SolidColorBrush x:Key="DangerBrush"      Color="{StaticResource Danger}"/>
      <SolidColorBrush x:Key="SuccessBrush"     Color="{StaticResource Success}"/>
      <SolidColorBrush x:Key="WarnBrush"        Color="{StaticResource Warn}"/>
    </Style.Resources>
  </Style>

  <!-- Window -->
  <Style Selector="Window">
    <Setter Property="Background" Value="{StaticResource BgMainBrush}"/>
    <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
    <Setter Property="FontSize" Value="13"/>
  </Style>

  <!-- UserControl -->
  <Style Selector="UserControl">
    <Setter Property="Background" Value="{StaticResource BgMainBrush}"/>
  </Style>

  <!-- TextBlock -->
  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="FontSize" Value="13"/>
  </Style>
  <Style Selector="TextBlock.title">
    <Setter Property="FontSize" Value="20"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="Margin" Value="0,0,0,16"/>
  </Style>
  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>
  <Style Selector="TextBlock.label">
    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Margin" Value="0,0,0,3"/>
  </Style>

  <!-- TextBox -->
  <Style Selector="TextBox">
    <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="10,7"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="SelectionBrush" Value="#33FFFFFF"/>
  </Style>
  <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="{StaticResource AccentMutedBrush}"/>
  </Style>

  <!-- ComboBox -->
  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="10,7"/>
    <Setter Property="FontSize" Value="13"/>
  </Style>

  <!-- Button base -->
  <Style Selector="Button">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="14,7"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>

  <!-- Основная кнопка -->
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
    <Setter Property="Foreground" Value="#000000"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>
  <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#CCCCCC"/>
  </Style>

  <!-- Вторичная кнопка (обводка) -->
  <Style Selector="Button.secondary">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>
  <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#1AFFFFFF"/>
  </Style>

  <!-- Опасная кнопка -->
  <Style Selector="Button.danger">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>
  <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#1ACC3333"/>
  </Style>

  <!-- Кнопка навигации -->
  <Style Selector="Button.nav">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="Padding" Value="18,11"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="CornerRadius" Value="0"/>
  </Style>
  <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#0FFFFFFF"/>
    <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}"/>
  </Style>

  <!-- Кнопки TitleBar -->
  <Style Selector="Button.tbBtn">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    <Setter Property="Width" Value="40"/>
    <Setter Property="Height" Value="32"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
  <Style Selector="Button.tbBtn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#1AFFFFFF"/>
  </Style>
  <Style Selector="Button.tbClose:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
    <Setter Property="TextElement.Foreground" Value="White"/>
  </Style>

  <!-- DataGrid -->
  <Style Selector="DataGrid">
    <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="RowBackground" Value="{StaticResource BgCardBrush}"/>
    <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="GridLinesVisibility" Value="Horizontal"/>
    <Setter Property="RowHeight" Value="36"/>
  </Style>
  <Style Selector="DataGridColumnHeader">
    <Setter Property="Background" Value="{StaticResource BgPanelBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Padding" Value="12,8"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
  </Style>
  <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
    <Setter Property="Fill" Value="#0AFFFFFF"/>
  </Style>
  <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
    <Setter Property="Fill" Value="#1AFFFFFF"/>
  </Style>
  <Style Selector="DataGridCell">
    <Setter Property="Padding" Value="12,0"/>
  </Style>

  <!-- ScrollViewer -->
  <Style Selector="ScrollViewer">
    <Setter Property="Background" Value="Transparent"/>
  </Style>

  <!-- Border.card -->
  <Style Selector="Border.card">
    <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="Padding" Value="24"/>
  </Style>

  <!-- Separator -->
  <Style Selector="Separator">
    <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
    <Setter Property="Height" Value="1"/>
    <Setter Property="Margin" Value="0,8"/>
  </Style>

</Styles>
