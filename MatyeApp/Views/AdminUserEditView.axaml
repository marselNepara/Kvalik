<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MatyeApp.Views.AdminUserEditView">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Width="360" Spacing="6">
            <TextBlock Text="Редактировать пользователя" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <TextBlock Text="Логин" Classes="label"/>
            <TextBox Name="LoginBox"/>

            <TextBlock Text="Email" Classes="label" Margin="0,10,0,0"/>
            <TextBox Name="EmailBox"/>

            <TextBlock Text="Телефон" Classes="label" Margin="0,10,0,0"/>
            <TextBox Name="PhoneBox"/>

            <TextBlock Text="Роль" Classes="label" Margin="0,10,0,0"/>
            <ComboBox Name="RoleBox" HorizontalAlignment="Stretch"/>

            <TextBlock Text="Баланс" Classes="label" Margin="0,10,0,0"/>
            <TextBox Name="BalanceBox"/>

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Classes="secondary" Content="Отмена" Click="CancelBtn_Click"/>
                <Button Classes="primary" Content="Сохранить" Click="SaveBtn_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
