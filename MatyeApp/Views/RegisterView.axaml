<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MatyeApp.Views.RegisterView">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Width="320" Spacing="6">
            <TextBlock Text="Регистрация" FontSize="18" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Логин" Classes="label"/>
            <TextBox Name="LoginBox" Watermark="логин"/>

            <TextBlock Text="Пароль" Classes="label" Margin="0,10,0,0"/>
            <TextBox Name="PasswordBox" Watermark="пароль" PasswordChar="•"/>

            <TextBlock Text="Email" Classes="label" Margin="0,10,0,0"/>
            <TextBox Name="EmailBox" Watermark="email"/>

            <TextBlock Text="Телефон" Classes="label" Margin="0,10,0,0"/>
            <TextBox Name="PhoneBox" Watermark="+7..."/>

            <Button Classes="primary" Content="Зарегистрироваться"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Margin="0,16,0,0" Click="RegisterBtn_Click"/>

            <Button Content="Уже есть аккаунт? Войти"
                    Classes="secondary" HorizontalAlignment="Center"
                    Margin="0,4,0,0" Click="BackToLogin_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
