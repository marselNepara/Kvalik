<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MatyeApp.Views.PaymentView">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Width="320" Spacing="6">
            <Button Content="← Назад" Classes="secondary" HorizontalAlignment="Left"
                    Margin="0,0,0,16" Click="BackBtn_Click"/>
            <TextBlock Text="Пополнение баланса" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <TextBlock Text="Номер карты" Classes="label"/>
            <TextBox Name="CardBox" Watermark="0000 0000 0000 0000" MaxLength="19"/>

            <TextBlock Text="Сумма" Classes="label" Margin="0,10,0,0"/>
            <TextBox Name="AmountBox" Watermark="0.00"/>

            <Button Classes="primary" Content="Пополнить"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Margin="0,16,0,0" Click="PayBtn_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
