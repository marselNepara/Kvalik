<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MatyeApp.Views.ServiceEditView">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Width="400" Spacing="6">
            <TextBlock Name="TitleLabel" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <TextBlock Text="Название" Classes="label"/>
            <TextBox Name="NameBox"/>

            <TextBlock Text="Описание" Classes="label" Margin="0,10,0,0"/>
            <TextBox Name="DescBox" Height="72" AcceptsReturn="True"/>

            <TextBlock Text="Цена" Classes="label" Margin="0,10,0,0"/>
            <TextBox Name="PriceBox"/>

            <TextBlock Text="Категория" Classes="label" Margin="0,10,0,0"/>
            <ComboBox Name="CategoryBox" HorizontalAlignment="Stretch"/>

            <TextBlock Text="Коллекция" Classes="label" Margin="0,10,0,0"/>
            <ComboBox Name="CollectionBox" HorizontalAlignment="Stretch"/>

            <TextBlock Text="URL изображения" Classes="label" Margin="0,10,0,0"/>
            <TextBox Name="ImageBox"/>

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Classes="secondary" Content="Отмена" Click="CancelBtn_Click"/>
                <Button Classes="primary" Content="Сохранить" Click="SaveBtn_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
